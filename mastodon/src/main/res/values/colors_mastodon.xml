<?xml version="1.0" encoding="utf-8"?>
<!--
    deen.social brand color overrides.
    Drop into mastodon-android/mastodon/src/main/res/values/colors_mastodon.xml
    (replaces the upstream file of the same name).

    Naming convention KEEPS the upstream slot names (mastodon_blurple_*,
    mastodon_eggplant_*) so Java/Kotlin call-sites don't need to change.
    Hex values are rebranded to Cielo.
-->
<resources>
    <!-- ─── Brand · Cielo ─────────────────────────────────────────────── -->
    <!-- Primary brand color · CTAs, tab-bar selected, links, FAB -->
    <color name="mastodon_blurple_600">#1B5BB0</color>   <!-- Deep · pressed state -->
    <color name="mastodon_blurple_500">#2A7FE0</color>   <!-- Brand · default -->
    <color name="mastodon_blurple_400">#4A95E8</color>   <!-- Hover/focus tint -->
    <color name="mastodon_blurple_300">#7FB8F2</color>   <!-- Light · highlights -->
    <color name="mastodon_blurple_200">#B8D6F7</color>   <!-- Pale tint surfaces -->

    <!-- Eggplant slot repurposed as deep-night surface -->
    <color name="mastodon_eggplant_800">#0A1929</color>  <!-- Carbon · dark bg -->
    <color name="mastodon_eggplant_700">#0F1F38</color>
    <color name="mastodon_eggplant_600">#16294A</color>
    <color name="mastodon_eggplant_500">#1E3559</color>

    <!-- Sand · accent < 5% (verified badges, optional gold detail) -->
    <color name="brand_sand">#D4B583</color>

    <!-- ─── Neutrals · warm ───────────────────────────────────────────── -->
    <color name="surface_bone">#FAF8F4</color>           <!-- Light bg -->
    <color name="surface_bone_2">#F2EFE9</color>         <!-- Light surface elevation -->
    <color name="ink_900">#1D1D1F</color>                <!-- Primary text light -->
    <color name="ink_500">#6C6F76</color>                <!-- Secondary text -->
    <color name="ink_300">#C7CAD1</color>                <!-- Hairline / divider -->

    <!-- Status -->
    <color name="status_success">#2E8B57</color>
    <color name="status_warning">#C98A1B</color>
    <color name="status_error">#C5443A</color>
</resources>
